{
  "info": {
    "name": "Pragya Medical API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1" },
    { "key": "token", "value": "" },
    { "key": "patient_id", "value": "" },
    { "key": "medicine_id", "value": "" },
    { "key": "invoice_id", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl | replace \"/api/v1\", \"\"}}/health"
      }
    },
    {
      "name": "Auth / Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Alice\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"secret\"\n}"
        }
      }
    },
    {
      "name": "Auth / Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"secret\"\n}"
        }
      }
    },
    {
      "name": "Patients / List",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/patients"
      }
    },
    {
      "name": "Patients / Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/patients",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Bob\",\n  \"mobile\": \"1234567890\",\n  \"age\": 40,\n  \"gender\": \"M\",\n  \"address\": \"Clinic Road\"\n}"
        }
      }
    },
    {
      "name": "Patients / Get",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/patients/{{patient_id}}"
      }
    },
    {
      "name": "Patients / Update",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/patients/{{patient_id}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"address\": \"New Address\",\n  \"age\": 41\n}"
        }
      }
    },
    {
      "name": "Patients / Delete",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/patients/{{patient_id}}"
      }
    },
    {
      "name": "Medicines / Add",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/patients/{{patient_id}}/medicines",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"brand\": \"Paracetamol\",\n  \"qty\": 30,\n  \"dose_per_day\": 2,\n  \"start_date\": \"2026-03-01T00:00:00Z\",\n  \"strength\": \"500mg\"\n}"
        }
      }
    },
    {
      "name": "Medicines / Update",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/medicines/{{medicine_id}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"qty\": 60,\n  \"dose_per_day\": 1\n}"
        }
      }
    },
    {
      "name": "Medicines / Delete",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/medicines/{{medicine_id}}"
      }
    },
    {
      "name": "Medicines / Refill",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/medicines/{{medicine_id}}/refill",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"qty\": 30,\n  \"start_date\": \"2026-03-20T00:00:00Z\"\n}"
        }
      }
    },
    {
      "name": "Reminders / List",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/reminders"
      }
    },
    {
      "name": "Reminders / Update Status",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/reminders/{{patient_id}}",
        "body": { "mode": "raw", "raw": "{\n  \"status\": \"sent\"\n}" }
      }
    },
    {
      "name": "Invoices / List",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/invoices"
      }
    },
    {
      "name": "Invoices / Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/invoices",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"patient_id\": \"{{patient_id}}\",\n  \"items\": [ { \"brand\": \"DrugA\", \"qty\": 10, \"unit_price\": 5.0, \"dose_per_day\": 1 } ],\n  \"discount\": 0\n}"
        }
      }
    },
    {
      "name": "Invoices / Get",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/invoices/{{invoice_id}}"
      }
    },
    {
      "name": "Invoices / Update",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/invoices/{{invoice_id}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"purchase_status\": \"paid\"\n}"
        }
      }
    },
    {
      "name": "Analytics",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/analytics"
      }
    },
    {
      "name": "Settings / Get",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/settings"
      }
    },
    {
      "name": "Settings / Update",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/settings",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"auto_reminder_on\": false,\n  \"remind_before_days\": 3,\n  \"reminder_mode\": \"whatsapp\"\n}"
        }
      }
    }
  ]
}
